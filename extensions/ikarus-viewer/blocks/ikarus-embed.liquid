<script>
  // Ikarus Cart Listener
  // Receives the viewer's "add to cart" message and adds the matched Shopify
  // variant(s) to the cart. Parent + child lines are tagged with bundle properties;
  // the Ikarus Cart Transform function (ikarus-bundle-transform) merges them into a
  // single bundle line server-side, so they display as ONE product in the cart, the
  // cart drawer, AND checkout — on any theme, with no DOM manipulation here.
  window.addEventListener('message', function (event) {
    if (!event.data || event.data.type !== 'IKARUS_SHOPIFY_ADD_TO_CART') return;

    // Variant IDs matched by the viewer (parent first when isParent sorting is applied upstream).
    var variantIds = Array.isArray(event.data.variantIds) && event.data.variantIds.length > 0
      ? event.data.variantIds
      : [event.data.variantId].filter(Boolean);

    if (variantIds.length === 0) {
      console.warn('[Ikarus] No variantIds — add to cart aborted. Check viewer variant matching.');
      return;
    }

    var bundleId = 'bundle_' + Date.now() + '_' + Math.random().toString(36).substr(2, 9);
    var isBundle = variantIds.length > 1;
    var configToken = event.data.configurationToken || '';

    var items = variantIds.map(function (vid, index) {
      var isParent = index === 0;
      var properties = Object.assign({}, event.data.properties || {});

      // Attribution: tag every viewer-sourced line so the orders/create webhook can
      // match it back to an order. Underscore-prefixed → hidden from cart/checkout UI.
      properties._source = '3d_viewer';
      properties._added_at = new Date().toISOString();
      properties._ikarus_config = configToken;

      // Bundle tagging — read by the Cart Transform function to merge the lines.
      if (isBundle) {
        properties._bundle_id = bundleId;
        properties._is_bundle_parent = isParent ? 'true' : 'false';
        properties._is_bundle_child = isParent ? 'false' : 'true';
      }

      return {
        id: Number(vid),
        quantity: event.data.quantity || 1,
        properties: properties
      };
    });

    // Notify the viewer + refresh the theme cart UI natively (no count/row hacks —
    // the Cart Transform already presents the bundle as one line).
    function finishCartAdd(addedItems) {
      var iframe = document.querySelector('iframe[id^="ikd-iframe-"]');
      if (iframe && iframe.contentWindow) {
        iframe.contentWindow.postMessage({ type: 'IKARUS_CART_SUCCESS', items: addedItems }, '*');
      }
      var cartDrawer = document.querySelector('cart-drawer');
      if (cartDrawer && typeof cartDrawer.open === 'function') {
        cartDrawer.open();
      } else {
        document.dispatchEvent(new CustomEvent('cart:refresh', { bubbles: true }));
        document.dispatchEvent(new CustomEvent('cart:open', { bubbles: true }));
      }
    }

    // Sequential fallback if the bulk add is rejected (e.g. a variant is unavailable).
    function addSequentially(queue, added) {
      var item = queue.shift();
      if (!item) { finishCartAdd(added); return; }
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify(item)
      })
        .then(function (r) { return r.json().then(function (res) { return { ok: r.ok, data: res }; }); })
        .then(function (result) {
          if (result.ok) added.push(result.data);
          else console.warn('[Ikarus] add failed for variant ' + item.id + ':', result.data);
          addSequentially(queue, added);
        })
        .catch(function (err) {
          console.error('[Ikarus] add fetch error for variant ' + item.id + ':', err);
          addSequentially(queue, added);
        });
    }

    // Bulk multi-add first; fall back to sequential on failure.
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ items: items })
    })
      .then(function (r) {
        if (r.ok) return r.json().then(function (result) { return { ok: true, result: result }; });
        return r.json().then(function (errBody) { return { ok: false, errBody: errBody }; })
          .catch(function () { return { ok: false, errBody: null }; });
      })
      .then(function (data) {
        if (data.ok) {
          finishCartAdd(data.result.items || [data.result]);
        } else {
          console.warn('[Ikarus] bulk add failed, falling back to sequential:', data.errBody);
          addSequentially(items.slice(), []);
        }
      })
      .catch(function (err) {
        console.error('[Ikarus] cart/add.js error:', err);
        addSequentially(items.slice(), []);
      });
  });
</script>

{% schema %}
{
  "name": "Ikarus Cart Listener",
  "target": "body"
}
{% endschema %}
