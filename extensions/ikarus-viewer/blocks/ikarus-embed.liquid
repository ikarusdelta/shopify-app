<script>
  window.addEventListener('message', function(event) {
    if (!event.data || event.data.type !== 'IKARUS_SHOPIFY_ADD_TO_CART') return;

    // Grab all variant IDs sent from React
    const variantIds = Array.isArray(event.data.variantIds) && event.data.variantIds.length > 0
      ? event.data.variantIds
      : [event.data.variantId].filter(Boolean);

    if (variantIds.length === 0) return;

    const bundleId = 'bundle_' + Date.now() + '_' + Math.random().toString(36).substr(2, 9);
    const isBundle = variantIds.length > 1;

    // Build items array for Shopify AJAX API
    const configToken = event.data.configurationToken || '';

    const items = variantIds.map(function(vid, index) {
      const isParent = index === 0;
      const baseProperties = event.data.properties || {};

      const properties = Object.assign({}, baseProperties);
      if (isBundle) {
        properties._bundle_id = bundleId;
        properties._is_bundle_parent = isParent ? 'true' : 'false';
        properties._is_bundle_child = isParent ? 'false' : 'true';
      }

      // Add each selected option as a visible cart property on the parent item.
      // Child items stay hidden via bundle logic, so only the parent needs display props.
      if (isParent && configToken) {
        configToken.split(',').forEach(function(token) {
          token = token.trim();
          if (!token) return;
          var colonIdx = token.indexOf(':');
          if (colonIdx > 0) {
            var key = token.substring(0, colonIdx).trim();
            var val = token.substring(colonIdx + 1).trim();
            if (key && val) properties[key] = val;
          }
        });
      }

      return {
        id: Number(vid),
        quantity: event.data.quantity || 1,
        properties: properties
      };
    });

    // --- Cart open / count refresh helper ---
    function finishCartAdd(addedItems) {
      const iframe = document.querySelector('iframe[id^="ikd-iframe-"]');
      if (iframe && iframe.contentWindow) {
        iframe.contentWindow.postMessage({ type: 'IKARUS_CART_SUCCESS', items: addedItems }, '*');
      }

      const cartDrawer = document.querySelector('cart-drawer');
      if (cartDrawer && typeof cartDrawer.open === 'function') {
        cartDrawer.open();
      } else {
        document.dispatchEvent(new CustomEvent('cart:refresh', { bubbles: true }));
        document.dispatchEvent(new CustomEvent('cart:open', { bubbles: true }));
      }

      fetch('/cart.js')
        .then(function(r) { return r.json(); })
        .then(function(cart) {
          // Subtract bundle child line items so the bubble shows the logical item count.
          var childCount = cart.items.filter(function(item) {
            return item.properties && item.properties._is_bundle_child === 'true';
          }).length;
          var displayCount = Math.max(0, cart.item_count - childCount);
          _applyCartCountDisplay(displayCount);
        });

      // Re-fetch and rebuild bundle data now that items are in the cart.
      // The IKARUS_CART_SUCCESS postMessage goes TO the iframe (not from it),
      // so the message listener below never fires — we call this directly instead.
      setTimeout(fetchCartAndBuildBundles, 700);
    }

    // --- Sequential single-item fallback ---
    function addSequentially(queue, added) {
      var item = queue.shift();
      if (!item) { finishCartAdd(added); return; }

      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify(item)
      })
      .then(function(r) { return r.json().then(function(res) { return { ok: r.ok, data: res }; }); })
      .then(function(result) {
        if (result.ok) added.push(result.data);
        addSequentially(queue, added);
      })
      .catch(function() {
        addSequentially(queue, added); // continue even on error
      });
    }

    // --- Try bulk multi-add first ---
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ items: items })
    })
    .then(function(r) {
      if (r.ok) return r.json().then(function(result) { return { ok: true, result: result }; });
      return r.json().then(function(errBody) { return { ok: false, status: r.status, errBody: errBody }; })
               .catch(function() { return { ok: false, status: r.status, errBody: null }; });
    })
    .then(function(data) {
      if (data.ok) {
        var addedItems = data.result.items || [data.result];
        finishCartAdd(addedItems);
      } else {
        addSequentially(items.slice(), []);
      }
    })
    .catch(function() {
      addSequentially(items.slice(), []);
    });
  });

  // --- Bundle Child Hiding & Parent Price Update ---
  var cachedBundles = null;
  var cachedCartItemCount = 0;

  function _applyCartCountDisplay(n) {
    document.querySelectorAll(
      '.cart-count-bubble span, .cart__count, [data-cart-count], .cart-icon-bubble span'
    ).forEach(function(el) {
      if (el.children.length > 0) return; // skip wrapper spans, only leaf nodes
      el.textContent = n;
    });
  }

  // All cart containers we try (nth-child CSS and position-based JS both use this list).
  var IKARUS_CONTAINERS = [
    // Dawn cart page: table.cart-items > tbody > tr.cart-item#CartItem-N
    'table.cart-items tbody',
    'cart-items form tbody',
    'cart-items table tbody',
    // Standard form-based
    'form[action="/cart"] tbody',
    'form[action$="/cart"] tbody',      // catches /en/cart locale prefixes
    'form[action="/cart"] ul',
    'form[action$="/cart"] ul',
    'form#cart tbody',
    'form#cart ul',
    // Named containers
    '#CartItems',
    '#CartDrawer-CartItems',
    // NOTE: '.cart-items' intentionally excluded — in Dawn it matches table.cart-items
    // (the TABLE itself), so > *:nth-child(N) targets <tbody> not a cart row.
    // Use 'table.cart-items tbody' (above) for Dawn.
    'cart-items',
    '.cart__items',
    '[data-cart-items]',
    // Other themes
    'form.cart tbody',
    'form.cart ul',
    '.cart-drawer__products',
    '.cart-drawer-items',
    '.cart-list',
    '.cart-products',
    '.mini-cart__items',
    '.cart-sidebar__items',
    // NOTE: [class*="cart-items"] is intentionally omitted — it can match table.cart-items
    // (the TABLE element), making > *:nth-child(N) target <tbody> instead of a cart row.
    // Use 'table.cart-items tbody' above for Dawn.
    // NOTE: [id*="cart-items"] is intentionally omitted — it matches #custom-cart-items-wrapper
    // (an Ikarus app block wrapper with 1 child div), so > *:nth-child(N) hides the wrapper div
    // instead of an individual cart row. Use '#custom-cart-items-wrapper > div' below instead.
    // Ikarus custom cart block (ikarus_delta_cart_items):
    // #custom-cart-items-wrapper > #custom-cart-items > .cart-items-container > DIV.cart-line (per item)
    '.cart-items-container',
    '#custom-cart-items-wrapper > div > div:first-child',
  ];

  // --- PRIMARY: CSS injection to hide child rows by position ---
  // Only runs when cart item containers are actually present in the DOM.
  // On pages that only have a cart-notification popup (no drawer, no /cart table),
  // matched will be empty and we skip — preventing rules from accidentally hiding
  // notification elements.
  function applyBundleCSS() {
    if (!cachedBundles) return;

    // Check which containers exist right now.
    var matched = IKARUS_CONTAINERS.filter(function(s) {
      try { return !!document.querySelector(s); } catch(e) { return false; }
    });

    var styleEl = document.getElementById('ikarus-bundle-css');

    if (!matched.length) {
      // No cart item containers on this page — clear any stale CSS and bail.
      if (styleEl) styleEl.innerHTML = '';
      return;
    }

    if (!styleEl) {
      styleEl = document.createElement('style');
      styleEl.id = 'ikarus-bundle-css';
      document.head.appendChild(styleEl);
    }

    var rules = [];
    Object.keys(cachedBundles).forEach(function(bid) {
      var b = cachedBundles[bid];
      if (!b.parent || !b.children.length) return;

      b.children.forEach(function(child) {
        var n = child._lineIndex; // 1-based
        // Only generate rules for containers that actually exist on this page.
        matched.forEach(function(csel) {
          rules.push(csel + ' > *:nth-child(' + n + ') { display: none !important; }');
        });
        // Dawn cart page: explicit full-path rules (safe regardless of matched list).
        rules.push('table.cart-items > tbody > tr:nth-child(' + n + ') { display: none !important; }');
        rules.push('cart-items table > tbody > tr:nth-child(' + n + ') { display: none !important; }');
        // Ikarus custom cart block (ikarus_delta_cart_items): explicit full path
        rules.push('#custom-cart-items > .cart-items-container > *:nth-child(' + n + ') { display: none !important; }');
        rules.push('.cart-items-container > .cart-line:nth-child(' + n + ') { display: none !important; }');
        // NOTE: class-wildcard row selectors like [class*="cart-item"]:nth-child(N) are intentionally
        // removed. They match elements that are the Nth child of ANY parent (not just cart containers),
        // e.g. div.cart-item-content is always :nth-child(1) of its parent div.cart-line, so n=1
        // hides the content div inside EVERY cart-line, not just the first one.
        // Use scoped container rules above instead.
        //
        // Table row fallback for Dawn-style themes (tr inside tbody, scoped to cart form)
        rules.push('form[action$="/cart"] tbody tr:nth-of-type(' + n + ') { display: none !important; }');
        rules.push('form#cart tbody tr:nth-of-type(' + n + ') { display: none !important; }');
      });
    });

    styleEl.innerHTML = rules.join('\n');
  }

  // --- SECONDARY: DOM manipulation to update parent price ---
  // Tries multiple ways to locate the parent cart item row, then patches the price text.
  function findParentRow(parentItem) {
    var n = parentItem._lineIndex;
    var vidStr = parentItem.variant_id ? parentItem.variant_id.toString() : '';
    var keyStr = parentItem.key || '';

    // 1. CartItem-N IDs (Dawn)
    var byId = document.getElementById('CartItem-' + n)
      || document.getElementById('CartDrawer-Item-' + n)
      || document.getElementById('cart-item-' + n);
    if (byId) return byId;

    // 2. data-key / data-variant-id
    var byAttr = document.querySelector('[data-key="' + keyStr + '"]')
      || document.querySelector('[data-variant-id="' + vidStr + '"]');
    if (byAttr) return byAttr.closest('tr, li, article, [class*="cart-item"], [class*="cart__item"], [class*="CartItem"]') || byAttr;

    // 3. href link containing variant ID or key
    var linkEl = document.querySelector('a[href*="' + vidStr + '"], a[href*="' + keyStr + '"]');
    if (linkEl) return linkEl.closest('tr, li, article, [class*="cart-item"], [class*="cart__item"], [class*="CartItem"]') || linkEl;

    // 4. Position-based: Nth child of a known cart container
    var containers = document.querySelectorAll(IKARUS_CONTAINERS.join(', '));
    for (var c = 0; c < containers.length; c++) {
      var cont = containers[c];
      var kids = Array.from(cont.children).filter(function(el) {
        var t = el.tagName; return t !== 'THEAD' && t !== 'TFOOT' && t !== 'SCRIPT' && t !== 'STYLE';
      });
      if (kids.length >= n) return kids[n - 1];
      // One level deeper
      for (var k = 0; k < kids.length; k++) {
        var gk = Array.from(kids[k].children).filter(function(el) {
          var t = el.tagName; return t !== 'THEAD' && t !== 'TFOOT' && t !== 'SCRIPT' && t !== 'STYLE';
        });
        if (gk.length >= n) return gk[n - 1];
      }
    }

    // 5. innerHTML scan for variant ID (last resort)
    if (vidStr) {
      var scanIn = document.querySelectorAll(IKARUS_CONTAINERS.join(', ') + ', form[action="/cart"]');
      if (!scanIn.length) scanIn = [document.body];
      for (var t2 = 0; t2 < scanIn.length; t2++) {
        var all = scanIn[t2].querySelectorAll('*');
        var best = null;
        for (var e = 0; e < all.length; e++) {
          if (all[e].innerHTML.indexOf(vidStr) === -1) continue;
          if (!best || all[e].innerHTML.length < best.innerHTML.length) best = all[e];
        }
        if (best) return best;
      }
    }

    return null;
  }

  function updateParentPrice(b) {
    var parentRow = findParentRow(b.parent);
    if (!parentRow) return;

    var oldCents = b.parent.final_line_price;
    var newCents = b.totalPrice;
    if (oldCents === newCents) return;

    var oldStr = (oldCents / 100).toFixed(2);
    var newStr = (newCents / 100).toFixed(2);
    var oldComma = parseFloat(oldStr).toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2});
    var newComma = parseFloat(newStr).toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2});

    // Include item-total / line-total classes in addition to price classes.
    // The Ikarus custom cart block uses div.item-total for the right-column line price.
    var priceSelector = '.price, [class*="price"], [class*="Price"], .item-total, [class*="item-total"], [class*="line-total"], [class*="line_price"], dd, span';
    parentRow.querySelectorAll(priceSelector).forEach(function(pel) {
      var text = pel.innerText || '';
      if (text.includes(oldStr)) {
        pel.innerHTML = pel.innerHTML.replace(new RegExp(oldStr.replace(/\./g, '\\.'), 'g'), newStr);
      } else if (oldComma !== oldStr && text.includes(oldComma)) {
        pel.innerHTML = pel.innerHTML.replace(new RegExp(oldComma.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'), 'g'), newComma);
      }
    });
  }

  // Combines parent and child variant_title strings into the parent's variant display element.
  // e.g. "Black / TM Pine / Virta" + "Self Winterized Shower / Thermo Ash / Fibre Optic Starlight Ceiling"
  // → "Black / TM Pine / Virta / Self Winterized Shower / Thermo Ash / Fibre Optic Starlight Ceiling"
  function updateBundleVariantDisplay(b) {
    if (!b.parent || !b.children.length) return;
    var parentRow = findParentRow(b.parent);
    if (!parentRow) return;

    var variantEl = parentRow.querySelector('.cart-item-variant, [class*="variant"]');
    if (!variantEl) return;

    var childTitles = b.children.map(function(c) { return c.variant_title || ''; }).filter(Boolean);
    if (!childTitles.length) return;

    var parentTitle = b.parent.variant_title || '';
    var combined = [parentTitle].concat(childTitles).filter(Boolean).join(' / ');
    if (variantEl.textContent === combined) return; // already correct
    variantEl.textContent = combined;
  }

  function enforceBundleVisuals() {
    if (!cachedBundles) return;
    applyBundleCSS(); // re-inject CSS on every tick (idempotent, no network)
    var totalChildren = 0;
    Object.keys(cachedBundles).forEach(function(bid) {
      var b = cachedBundles[bid];
      if (b.parent && b.children.length) {
        totalChildren += b.children.length;
        updateParentPrice(b);
        updateBundleVariantDisplay(b);
      }
    });
    if (totalChildren > 0 && cachedCartItemCount > 0) {
      _applyCartCountDisplay(Math.max(0, cachedCartItemCount - totalChildren));
    }
  }

  function fetchCartAndBuildBundles() {
    fetch('/cart.js')
      .then(function(r) { return r.json(); })
      .then(function(cart) {
        var bundles = {};
        cart.items.forEach(function(item, index) {
          item._lineIndex = index + 1; // 1-based position matching Liquid loop order
          if (item.properties && item.properties._bundle_id) {
            var bid = item.properties._bundle_id;
            if (!bundles[bid]) bundles[bid] = { parent: null, children: [], totalPrice: 0, totalOriginalPrice: 0 };
            if (item.properties._is_bundle_parent === 'true') bundles[bid].parent = item;
            else if (item.properties._is_bundle_child === 'true') bundles[bid].children.push(item);
            bundles[bid].totalPrice += item.final_line_price;
            bundles[bid].totalOriginalPrice += item.original_line_price;
          }
        });
        cachedBundles = bundles;
        cachedCartItemCount = cart.item_count;
        applyBundleCSS();      // inject CSS immediately
        enforceBundleVisuals(); // then try price/variant/count update
      })
      .catch(function() {});
  }

  // Intercept Remove button clicks on bundle PARENT rows.
  // Uses capture phase so we fire before the Ikarus cart block's React handler.
  // Non-bundle rows are untouched — we return early and the native handler runs.
  document.addEventListener('click', function(event) {
    var btn = event.target && event.target.closest
      ? event.target.closest('.remove-btn, [class*="remove-btn"], [class*="RemoveButton"], [data-remove]')
      : null;
    if (!btn || !cachedBundles) return;

    var cartLine = btn.closest('.cart-line, [class*="cart-line"]');
    if (!cartLine) return;

    var container = document.querySelector('.cart-items-container');
    if (!container) return;
    var lineIdx = Array.from(container.children).indexOf(cartLine) + 1; // 1-based
    if (!lineIdx) return;

    // Find the bundle whose PARENT lives at this line index
    var match = null;
    Object.keys(cachedBundles).forEach(function(bid) {
      var b = cachedBundles[bid];
      if (b.parent && b.parent._lineIndex === lineIdx) match = b;
    });
    if (!match) return; // not a bundle parent — let default handler run

    // It IS a bundle parent — block the block's handler and remove everything
    event.preventDefault();
    event.stopPropagation();

    var updates = {};
    updates[match.parent.key] = 0;
    match.children.forEach(function(c) { updates[c.key] = 0; });

    fetch('/cart/update.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ updates: updates })
    })
    .then(function() { window.location.reload(); })
    .catch(function() { window.location.reload(); });
  }, true /* capture phase */);

  document.addEventListener('DOMContentLoaded', fetchCartAndBuildBundles);
  window.addEventListener('message', function(event) {
    if (event.data && event.data.type === 'IKARUS_CART_SUCCESS') {
      setTimeout(fetchCartAndBuildBundles, 500);
    }
  });

  setInterval(enforceBundleVisuals, 500);
</script>

{% schema %}
{
  "name": "Ikarus Cart Listener",
  "target": "body"
}
{% endschema %}