<script>
  window.addEventListener('message', function(event) {
    if (!event.data || event.data.type !== 'IKARUS_SHOPIFY_ADD_TO_CART') return;
    console.log('[Ikarus App Embed] ✅ Got message:', event.data);

    // FIXED: Use the pre-built items array from the iframe payload to preserve individual properties/prices
    let items = [];
    if (Array.isArray(event.data.items) && event.data.items.length > 0) {
      items = event.data.items.map(function(item) {
        return {
          id: Number(item.id),
          quantity: Number(item.quantity || event.data.quantity || 1),
          properties: item.properties || {}
        };
      });
    } else {
      // Fallback for legacy single-product variant blocks
      const variantId = event.data.variantId || (Array.isArray(event.data.variantIds) ? event.data.variantIds[0] : null);
      if (variantId) {
        items.push({
          id: Number(variantId),
          quantity: event.data.quantity || 1,
          properties: event.data.properties || {}
        });
      }
    }

    if (items.length === 0) {
      console.warn('[Ikarus] ⚠️ No items found to add to cart.');
      return;
    }

    console.log('[Ikarus] Submitting items to Shopify cart API:', items);

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ items: items })
    })
    .then(function(r) { return r.json(); })
    .then(function(result) {
      console.log('[Ikarus] ✅ Added to cart:', result);
      
      const iframe = document.querySelector('iframe[id^="ikd-iframe-"]');
      if (iframe && iframe.contentWindow) {
        iframe.contentWindow.postMessage({ type: 'IKARUS_CART_SUCCESS', item: result }, '*');
      }

      const cartDrawer = document.querySelector('cart-drawer');
      if (cartDrawer && typeof cartDrawer.open === 'function') {
        cartDrawer.open();
      } else {
        document.dispatchEvent(new CustomEvent('cart:refresh', { bubbles: true }));
        document.dispatchEvent(new CustomEvent('cart:open', { bubbles: true }));
      }

      fetch('/cart.js').then(function(r) { return r.json(); }).then(function(cart) {
        document.querySelectorAll(
          '.cart-count-bubble span, .cart__count, [data-cart-count], .cart-icon-bubble span'
        ).forEach(function(el) { el.textContent = cart.item_count; });
      });
    })
    .catch(function(err) {
      console.error('[Ikarus] Cart error:', err);
    });
  });
</script>

{% schema %}
{
  "name": "Ikarus Cart Listener",
  "target": "body"
}
{% endschema %}