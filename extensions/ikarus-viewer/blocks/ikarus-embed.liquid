<script>
  window.addEventListener('message', function(event) {
    if (!event.data || event.data.type !== 'IKARUS_SHOPIFY_ADD_TO_CART') return;
    console.log('[Ikarus App Embed] ✅ Got message:', event.data);

    // Grab all variant IDs sent from React
    const variantIds = Array.isArray(event.data.variantIds) && event.data.variantIds.length > 0
      ? event.data.variantIds
      : [event.data.variantId].filter(Boolean);

    if (variantIds.length === 0) {
      console.warn('[Ikarus] ⚠️ No variant IDs found in payload.');
      return;
    }

    const bundleId = 'bundle_' + Date.now() + '_' + Math.random().toString(36).substr(2, 9);
    const isBundle = variantIds.length > 1;

    // Build items array for Shopify AJAX API
    const configToken = event.data.configurationToken || '';

    const items = variantIds.map(function(vid, index) {
      const isParent = index === 0;
      const baseProperties = event.data.properties || {};

      const properties = Object.assign({}, baseProperties);
      if (isBundle) {
        properties._bundle_id = bundleId;
        properties._is_bundle_parent = isParent ? 'true' : 'false';
        properties._is_bundle_child = isParent ? 'false' : 'true';
      }

      // Add each selected option as a visible cart property on the parent item.
      // Child items stay hidden via bundle logic, so only the parent needs display props.
      if (isParent && configToken) {
        configToken.split(',').forEach(function(token) {
          token = token.trim();
          if (!token) return;
          var colonIdx = token.indexOf(':');
          if (colonIdx > 0) {
            var key = token.substring(0, colonIdx).trim();
            var val = token.substring(colonIdx + 1).trim();
            if (key && val) properties[key] = val;
          }
        });
      }

      return {
        id: Number(vid),
        quantity: event.data.quantity || 1,
        properties: properties
      };
    });

    console.log('[Ikarus] Adding items to Shopify cart:', items);

    // --- Cart open / count refresh helper ---
    function finishCartAdd(addedItems) {
      console.log('[Ikarus] ✅ All done. Added items:', addedItems);

      const iframe = document.querySelector('iframe[id^="ikd-iframe-"]');
      if (iframe && iframe.contentWindow) {
        iframe.contentWindow.postMessage({ type: 'IKARUS_CART_SUCCESS', items: addedItems }, '*');
      }

      const cartDrawer = document.querySelector('cart-drawer');
      if (cartDrawer && typeof cartDrawer.open === 'function') {
        cartDrawer.open();
      } else {
        document.dispatchEvent(new CustomEvent('cart:refresh', { bubbles: true }));
        document.dispatchEvent(new CustomEvent('cart:open', { bubbles: true }));
      }

      fetch('/cart.js')
        .then(function(r) { return r.json(); })
        .then(function(cart) {
          document.querySelectorAll(
            '.cart-count-bubble span, .cart__count, [data-cart-count], .cart-icon-bubble span'
          ).forEach(function(el) { el.textContent = cart.item_count; });
        });

      // Re-fetch and rebuild bundle data now that items are in the cart.
      // The IKARUS_CART_SUCCESS postMessage goes TO the iframe (not from it),
      // so the message listener below never fires — we call this directly instead.
      setTimeout(fetchCartAndBuildBundles, 700);
    }

    // --- Sequential single-item fallback ---
    function addSequentially(queue, added) {
      var item = queue.shift();
      if (!item) { finishCartAdd(added); return; }

      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify(item)
      })
      .then(function(r) { return r.json().then(function(res) { return { ok: r.ok, data: res }; }); })
      .then(function(result) {
        if (result.ok) {
          console.log('[Ikarus] ✅ Sequential add succeeded:', result.data);
          added.push(result.data);
        } else {
          console.error('[Ikarus] ❌ Sequential add failed for variant', item.id, result.data);
        }
        addSequentially(queue, added);
      })
      .catch(function(err) {
        console.error('[Ikarus] Sequential add failed for variant', item.id, err);
        addSequentially(queue, added); // continue even on error
      });
    }

    // --- Try bulk multi-add first ---
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ items: items })
    })
    .then(function(r) {
      if (r.ok) return r.json().then(function(result) { return { ok: true, result: result }; });
      // Read Shopify's error body so we can log it before falling back
      return r.json().then(function(errBody) { return { ok: false, status: r.status, errBody: errBody }; })
               .catch(function() { return { ok: false, status: r.status, errBody: null }; });
    })
    .then(function(data) {
      if (data.ok) {
        // Bulk add worked
        var addedItems = data.result.items || [data.result];
        console.log('[Ikarus] ✅ Bulk add succeeded:', addedItems);
        finishCartAdd(addedItems);
      } else {
        // Log what Shopify said and fall back to sequential
        console.warn('[Ikarus] ⚠️ Bulk add returned', data.status, '– Shopify said:', data.errBody);
        console.warn('[Ikarus] Falling back to sequential single-item adds...');
        addSequentially(items.slice(), []);
      }
    })
    .catch(function(err) {
      console.error('[Ikarus] Network error on bulk add, falling back:', err);
      addSequentially(items.slice(), []);
    });
  });

  // --- Auto-Hide Bundle Children ---
  var cachedBundles = null;

  // 1. Fetch cart mapping from Shopify API
  function fetchCartAndBuildBundles() {
    fetch('/cart.js')
      .then(function(r) { return r.json(); })
      .then(function(cart) {
        var bundles = {};
        cart.items.forEach(function(item, index) {
          // Store 1-based line index so enforceBundleVisuals can target CartItem-N
          item._lineIndex = index + 1;

          if (item.properties && item.properties._bundle_id) {
            var bid = item.properties._bundle_id;
            if (!bundles[bid]) bundles[bid] = { parent: null, children: [], totalPrice: 0, totalOriginalPrice: 0 };

            if (item.properties._is_bundle_parent === 'true') {
              bundles[bid].parent = item;
            } else if (item.properties._is_bundle_child === 'true') {
              bundles[bid].children.push(item);
            }
            bundles[bid].totalPrice += item.final_line_price;
            bundles[bid].totalOriginalPrice += item.original_line_price;
          }
        });
        cachedBundles = bundles;
        enforceBundleVisuals();
      })
      .catch(function(e) { console.error('[Ikarus] Error fetching cart', e); });
  }

  // Ordered list of selectors that identify individual cart item rows.
  var ITEM_ROW_SELS = [
    'tr.cart-item', 'li.cart-item', 'article.cart-item',
    '[class*="CartItem__"]',                  // CartItem__Root etc.
    '.cart__row', '.cart__item',
    '.cart-line-item', '.cart-product',
    '[data-cart-item]',
    'tr[id^="CartItem-"]', 'tr[id^="cart-item-"]',
    'tr',                                     // plain table rows as last tr fallback
  ];

  // Containers that hold ONLY cart item rows (no noise from other page sections).
  var CART_CONTAINER_SELS = [
    '#CartItems',
    '#CartDrawer-CartItems',
    '.cart-items',
    'cart-items',
    '.cart__items',
    '[data-cart-items]',
    'form[action="/cart"] tbody',
    'form[action="/cart"] ul',
    'form.cart tbody',
    'form.cart ul',
  ];

  // Find the DOM row for a cart item using multiple strategies.
  function findCartItemRow(item) {
    var lineIndex = item._lineIndex;   // 1-based position in cart.js order
    var keyStr = item.key || '';
    var keyEnc = encodeURIComponent(keyStr);
    var vidStr = item.variant_id ? item.variant_id.toString() : '';
    var ROW_CLOSEST = ITEM_ROW_SELS.slice(0, -1).join(', '); // for .closest()

    // Strategy 1: CartItem-N / CartDrawer-Item-N (Dawn and Dawn-based themes)
    if (lineIndex) {
      var byId = document.getElementById('CartItem-' + lineIndex)
        || document.getElementById('CartDrawer-Item-' + lineIndex)
        || document.getElementById('cart-item-' + lineIndex);
      if (byId) return byId;
    }

    // Strategy 2: data-key attribute (some modern themes)
    if (keyStr) {
      var byKey = document.querySelector('[data-key="' + keyStr + '"]');
      if (byKey) return byKey.closest(ROW_CLOSEST) || byKey;
    }

    // Strategy 3: data-variant-id / data-product-variant-id attribute
    if (vidStr) {
      var byVid = document.querySelector(
        '[data-variant-id="' + vidStr + '"], [data-product-variant-id="' + vidStr + '"]'
      );
      if (byVid) return byVid.closest(ROW_CLOSEST) || byVid;
    }

    // Strategy 4: links or elements whose href/id contains the cart key or variant ID
    var attrSel = [];
    if (keyStr) attrSel.push('a[href*="' + keyStr + '"]', 'a[href*="' + keyEnc + '"]', '[id*="' + keyStr + '"]');
    if (vidStr) attrSel.push('a[href*="' + vidStr + '"]');
    if (attrSel.length) {
      var attrEls = document.querySelectorAll(attrSel.join(', '));
      for (var i = 0; i < attrEls.length; i++) {
        var r4 = attrEls[i].closest(ROW_CLOSEST);
        if (r4) return r4;
      }
    }

    // Strategy 5: hidden inputs whose value is the variant ID
    if (vidStr) {
      var inputs = document.querySelectorAll('input[value="' + vidStr + '"]');
      for (var j = 0; j < inputs.length; j++) {
        var r5 = inputs[j].closest(ROW_CLOSEST);
        if (r5) return r5;
      }
    }

    // Strategy 6: Position-based inside each cart container.
    // cart.js item order matches the Liquid render order, so the Nth child = Nth cart item.
    // We try specific row selectors first, then fall back to raw direct/2nd-level children.
    if (lineIndex) {
      var containers6 = document.querySelectorAll(CART_CONTAINER_SELS.join(', '));
      for (var c = 0; c < containers6.length; c++) {
        var cont = containers6[c];

        // 6a: specific row selectors inside this container
        for (var s = 0; s < ITEM_ROW_SELS.length; s++) {
          var rows = cont.querySelectorAll(ITEM_ROW_SELS[s]);
          if (rows.length >= lineIndex) return rows[lineIndex - 1];
        }

        // 6b: direct children (any tag) — covers themes with no standard class names
        var kids = Array.from(cont.children).filter(function(el) {
          var t2 = el.tagName;
          return t2 !== 'THEAD' && t2 !== 'TFOOT' && t2 !== 'SCRIPT' && t2 !== 'STYLE';
        });
        if (kids.length >= lineIndex) return kids[lineIndex - 1];

        // 6c: grandchildren (container > wrapper > item, e.g. div > ul > li)
        for (var k = 0; k < kids.length; k++) {
          var grandkids = Array.from(kids[k].children).filter(function(el) {
            var t3 = el.tagName;
            return t3 !== 'THEAD' && t3 !== 'TFOOT' && t3 !== 'SCRIPT' && t3 !== 'STYLE';
          });
          if (grandkids.length >= lineIndex) return grandkids[lineIndex - 1];
        }
      }

      // 6d: global DOM order — no container found, try any matching element globally
      for (var s2 = 0; s2 < ITEM_ROW_SELS.length; s2++) {
        var globalRows = document.querySelectorAll(ITEM_ROW_SELS[s2]);
        if (globalRows.length >= lineIndex) return globalRows[lineIndex - 1];
      }
    }

    // Strategy 7 (nuclear): find smallest element in a cart container whose innerHTML
    // contains the variant ID.  Uses innerHTML scan only as absolute last resort.
    if (vidStr) {
      var scanRoots7 = document.querySelectorAll(CART_CONTAINER_SELS.join(', ') + ', form[action="/cart"]');
      if (!scanRoots7.length) scanRoots7 = [document.body];
      for (var t = 0; t < scanRoots7.length; t++) {
        var all7 = scanRoots7[t].querySelectorAll('*');
        var best7 = null;
        for (var e = 0; e < all7.length; e++) {
          var el7 = all7[e];
          if (el7.innerHTML.indexOf(vidStr) === -1) continue;
          if (!best7 || el7.innerHTML.length < best7.innerHTML.length) best7 = el7;
        }
        if (best7) return best7;
      }
    }

    // --- Diagnostic (fires once per variant, only when a cart container IS in the DOM) ---
    if (!findCartItemRow._logged) findCartItemRow._logged = {};
    var diagKey = vidStr + ':' + lineIndex;
    if (!findCartItemRow._logged[diagKey]) {
      findCartItemRow._logged[diagKey] = true;
      var diag = document.querySelector(CART_CONTAINER_SELS.join(', '));
      if (diag) {
        console.group('[Ikarus] ❌ Cart row not found — theme structure needed');
        console.log('Variant ID:', vidStr, '| Line index:', lineIndex);
        console.log('Container tag/id/class:', diag.tagName, diag.id, diag.className);
        console.log('Direct child count:', diag.children.length);
        if (diag.children[0]) {
          var fc = diag.children[0];
          console.log('First child:', fc.tagName, fc.id, fc.className);
          if (fc.children[0]) {
            var gc = fc.children[0];
            console.log('First grandchild:', gc.tagName, gc.id, gc.className);
          }
        }
        console.log('Container outerHTML (first 600 chars):\n', diag.outerHTML.substring(0, 600));
        console.groupEnd();
      }
    }
    return null;
  }

  // 2. Continually enforce DOM changes using cached data (No network requests!)
  function enforceBundleVisuals() {
    if (!cachedBundles) return;
    
    Object.keys(cachedBundles).forEach(function(bid) {
      var b = cachedBundles[bid];
      if (!b.parent || b.children.length === 0) return;

      // Hide children
      b.children.forEach(function(child) {
        var row = findCartItemRow(child);
        if (row) {
          row.style.setProperty('display', 'none', 'important');
        }
      });

      // Update parent price to show the combined bundle total
      var parentRow = findCartItemRow(b.parent);
      if (parentRow && !parentRow.dataset.ikarusPriceUpdated) {
        var oldCents = b.parent.final_line_price;
        var newCents = b.totalPrice;
        if (oldCents !== newCents) {
          var oldStr = (oldCents / 100).toFixed(2);
          var newStr = (newCents / 100).toFixed(2);
          var oldStrComma = parseFloat(oldStr).toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2});
          var newStrComma = parseFloat(newStr).toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2});

          parentRow.querySelectorAll('.price, .cart-item__price-wrapper, [data-cart-item-price], .cart-item__totals, .cart__price, .cart-item__price, dd, span').forEach(function(pel) {
            var text = pel.innerText || '';
            if (text.includes(oldStr)) {
              pel.innerHTML = pel.innerHTML.replace(new RegExp(oldStr, 'g'), newStr);
            } else if (oldStrComma !== oldStr && text.includes(oldStrComma)) {
              pel.innerHTML = pel.innerHTML.replace(new RegExp(oldStrComma.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'), 'g'), newStrComma);
            }
          });
        }
        parentRow.dataset.ikarusPriceUpdated = 'true';
      }
    });
  }

  // Network triggers
  document.addEventListener('DOMContentLoaded', fetchCartAndBuildBundles);
  window.addEventListener('message', function(event) {
    if (event.data && event.data.type === 'IKARUS_CART_SUCCESS') {
       setTimeout(fetchCartAndBuildBundles, 500);
    }
  });

  // DOM trigger (Runs 2 times a second, completely safe because it makes 0 network requests)
  setInterval(enforceBundleVisuals, 500);
</script>

{% schema %}
{
  "name": "Ikarus Cart Listener",
  "target": "body"
}
{% endschema %}