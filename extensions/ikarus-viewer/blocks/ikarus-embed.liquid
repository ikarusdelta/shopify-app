<script>
  window.addEventListener('message', function(event) {
    if (!event.data || event.data.type !== 'IKARUS_SHOPIFY_ADD_TO_CART') return;
    console.log('[Ikarus App Embed] ✅ Got message:', event.data);

    // Grab all variant IDs sent from React
    const variantIds = Array.isArray(event.data.variantIds) && event.data.variantIds.length > 0
      ? event.data.variantIds
      : [event.data.variantId].filter(Boolean);

    if (variantIds.length === 0) {
      console.warn('[Ikarus] ⚠️ No variant IDs found in payload.');
      return;
    }

    // Map to Shopify AJAX API items format
    const items = variantIds.map(function(vid) {
      return {
        id: Number(vid),
        quantity: event.data.quantity || 1,
        properties: event.data.properties || {}
      };
    });

    console.log('[Ikarus] Adding items to Shopify cart:', items);

    fetch('/cart/add.js', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Accept': 'application/json'
      },
      body: JSON.stringify({ items: items })
    })
    .then(function(r) {
      if (!r.ok) {
        throw new Error('HTTP error! status: ' + r.status);
      }
      return r.json();
    })
    .then(function(result) {
      console.log('[Ikarus] ✅ Successfully added to cart:', result);

      // Notify iframe of success
      const iframe = document.querySelector('iframe[id^="ikd-iframe-"]');
      if (iframe && iframe.contentWindow) {
        iframe.contentWindow.postMessage({ type: 'IKARUS_CART_SUCCESS', items: result.items || [result] }, '*');
      }

      // Trigger the cart drawer or dispatch cart open/refresh events
      const cartDrawer = document.querySelector('cart-drawer');
      if (cartDrawer && typeof cartDrawer.open === 'function') {
        cartDrawer.open();
      } else {
        document.dispatchEvent(new CustomEvent('cart:refresh', { bubbles: true }));
        document.dispatchEvent(new CustomEvent('cart:open', { bubbles: true }));
      }

      // Update cart count bubbles on page
      fetch('/cart.js')
        .then(function(r) { return r.json(); })
        .then(function(cart) {
          document.querySelectorAll(
            '.cart-count-bubble span, .cart__count, [data-cart-count], .cart-icon-bubble span'
          ).forEach(function(el) { el.textContent = cart.item_count; });
        });
    })
    .catch(function(err) {
      console.error('[Ikarus] Cart error adding items:', err);
    });
  });
</script>

{% schema %}
{
  "name": "Ikarus Cart Listener",
  "target": "body"
}
{% endschema %}