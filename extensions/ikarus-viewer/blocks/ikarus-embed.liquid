<script>
  // Ikarus Cart Listener
  // Receives the viewer's "add to cart" message and adds the matched variant(s) to the
  // Shopify cart, tagging bundle lines with _bundle_id / _is_bundle_parent / _is_bundle_child.
  //
  // Presentation of bundles in the cart (grouping parent + child, showing the combined
  // options, hiding child rows, count) is handled by the Ikarus `cart-items` cart block,
  // which is bundle-aware and reads those properties. We intentionally do NOT manipulate
  // the cart DOM here — doing so fought the cart block's own rendering.
  window.addEventListener('message', function (event) {
    if (!event.data || event.data.type !== 'IKARUS_SHOPIFY_ADD_TO_CART') return;

    // Variant IDs sent from the viewer (parent first, then children).
    var variantIds = Array.isArray(event.data.variantIds) && event.data.variantIds.length > 0
      ? event.data.variantIds
      : [event.data.variantId].filter(Boolean);

    if (variantIds.length === 0) {
      console.warn('[EMBED] No variantIds — add to cart aborted. Check viewer variant matching.');
      return;
    }

    var bundleId = 'bundle_' + Date.now() + '_' + Math.random().toString(36).substr(2, 9);
    var isBundle = variantIds.length > 1;
    var configToken = event.data.configurationToken || '';

    var items = variantIds.map(function (vid, index) {
      var isParent = index === 0;
      var properties = Object.assign({}, event.data.properties || {});

      if (isBundle) {
        properties._bundle_id = bundleId;
        properties._is_bundle_parent = isParent ? 'true' : 'false';
        properties._is_bundle_child = isParent ? 'false' : 'true';
      }

      // Expose each selected option as a cart line property on the parent line.
      if (isParent && configToken) {
        configToken.split(',').forEach(function (token) {
          token = token.trim();
          if (!token) return;
          var colonIdx = token.indexOf(':');
          if (colonIdx > 0) {
            var key = token.substring(0, colonIdx).trim();
            var val = token.substring(colonIdx + 1).trim();
            if (key && val) properties[key] = val;
          }
        });
      }

      return { id: Number(vid), quantity: event.data.quantity || 1, properties: properties };
    });

    // Open the cart (drawer if present) and tell the viewer the add succeeded.
    function finishCartAdd(addedItems) {
      var iframe = document.querySelector('iframe[id^="ikd-iframe-"]');
      if (iframe && iframe.contentWindow) {
        iframe.contentWindow.postMessage({ type: 'IKARUS_CART_SUCCESS', items: addedItems }, '*');
      }
      var cartDrawer = document.querySelector('cart-drawer');
      if (cartDrawer && typeof cartDrawer.open === 'function') {
        cartDrawer.open();
      } else {
        document.dispatchEvent(new CustomEvent('cart:refresh', { bubbles: true }));
        document.dispatchEvent(new CustomEvent('cart:open', { bubbles: true }));
      }
    }

    // Sequential single-item fallback if the bulk add is rejected.
    function addSequentially(queue, added) {
      var item = queue.shift();
      if (!item) { finishCartAdd(added); return; }
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify(item)
      })
        .then(function (r) { return r.json().then(function (res) { return { ok: r.ok, data: res }; }); })
        .then(function (result) {
          if (result.ok) added.push(result.data);
          else console.warn('[EMBED] sequential add failed variantId=' + item.id + ':', result.data);
          addSequentially(queue, added);
        })
        .catch(function () { addSequentially(queue, added); });
    }

    // Bulk multi-add first.
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ items: items })
    })
      .then(function (r) {
        if (r.ok) return r.json().then(function (result) { return { ok: true, result: result }; });
        return r.json().then(function (errBody) { return { ok: false, status: r.status, errBody: errBody }; })
          .catch(function () { return { ok: false, status: r.status, errBody: null }; });
      })
      .then(function (data) {
        if (data.ok) {
          finishCartAdd(data.result.items || [data.result]);
        } else {
          console.warn('[EMBED] bulk cart/add.js failed (' + data.status + '), falling back:', data.errBody);
          addSequentially(items.slice(), []);
        }
      })
      .catch(function (err) {
        console.error('[EMBED] cart/add.js error:', err);
        addSequentially(items.slice(), []);
      });
  });
</script>
