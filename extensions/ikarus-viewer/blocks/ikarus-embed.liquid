<script>
  window.addEventListener('message', function(event) {
    if (!event.data || event.data.type !== 'IKARUS_SHOPIFY_ADD_TO_CART') return;
    console.log('[Ikarus App Embed] ✅ Got message:', event.data);

    // Grab all variant IDs sent from React
    const variantIds = Array.isArray(event.data.variantIds) && event.data.variantIds.length > 0
      ? event.data.variantIds
      : [event.data.variantId].filter(Boolean);

    if (variantIds.length === 0) {
      console.warn('[Ikarus] ⚠️ No variant IDs found in payload.');
      return;
    }

    // Build the queue of items
    const bundleId = Date.now().toString();
    const itemsToQueue = variantIds.map(function(vid, index) {
      let props = Object.assign({}, event.data.properties || {});
      
      // If there are multiple variants, tag them as a bundle
      if (variantIds.length > 1) {
        props['_ikarus_bundle'] = bundleId;
        props['_ikarus_role'] = index === 0 ? 'parent' : 'addon';
      }

      return {
        id: Number(vid),
        quantity: event.data.quantity || 1,
        properties: props
      };
    });

    console.log('[Ikarus] Sequentially adding items to cart to bypass theme interceptor:', itemsToQueue);

    let addedItems = [];

    // Process the queue one-by-one to force Shopify to accept all products
    function addNextItem() {
      const item = itemsToQueue.shift();
      
      // If queue is empty, trigger the cart drawer open
      if (!item) {
        console.log('[Ikarus] ✅ All items successfully added to cart:', addedItems);
        finishCartAdd(addedItems);
        return;
      }

      // Send as a single object to bypass strict theme array blocks
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify(item) 
      })
      .then(function(r) { return r.json(); })
      .then(function(result) {
        addedItems.push(result);
        addNextItem(); // Recursively call the next item in the queue
      })
      .catch(function(err) {
        console.error('[Ikarus] Cart error on item:', item.id, err);
        addNextItem(); // Continue to next item even if one fails
      });
    }

    // Start the sequential add process
    addNextItem();

    // Fire cart events when queue finishes
    function finishCartAdd(results) {
      const iframe = document.querySelector('iframe[id^="ikd-iframe-"]');
      if (iframe && iframe.contentWindow) {
        iframe.contentWindow.postMessage({ type: 'IKARUS_CART_SUCCESS', items: results }, '*');
      }
      
      const cartDrawer = document.querySelector('cart-drawer');
      if (cartDrawer && typeof cartDrawer.open === 'function') {
        cartDrawer.open();
      } else {
        document.dispatchEvent(new CustomEvent('cart:refresh', { bubbles: true }));
        document.dispatchEvent(new CustomEvent('cart:open', { bubbles: true }));
      }
      
      fetch('/cart.js').then(function(r) { return r.json(); }).then(function(cart) {
        document.querySelectorAll(
          '.cart-count-bubble span, .cart__count, [data-cart-count], .cart-icon-bubble span'
        ).forEach(function(el) { el.textContent = cart.item_count; });
      });
    }
  });

  // --- Ikarus Cart Visual Merger ---
  // This script attempts to find add-on items in the cart and hide them,
  // while adding their price to the parent item.
  (function() {
    let lastCartState = null;

    async function fetchCart() {
      try {
        const res = await fetch('/cart.js');
        return await res.json();
      } catch(e) {
        return null;
      }
    }

    async function updateCartUI() {
      const cart = await fetchCart();
      if (!cart || !cart.items) return;
      lastCartState = cart;

      // Group by bundle
      const bundles = {};
      cart.items.forEach(function(item) {
        if (item.properties && item.properties['_ikarus_bundle']) {
          const bId = item.properties['_ikarus_bundle'];
          if (!bundles[bId]) bundles[bId] = { parent: null, addons: [], totalPrice: 0 };
          
          bundles[bId].totalPrice += item.original_line_price; // Summing total line price

          if (item.properties['_ikarus_role'] === 'parent') {
            bundles[bId].parent = item;
          } else {
            bundles[bId].addons.push(item);
          }
        }
      });

      // Now attempt to hide addons in the DOM and update parent prices
      Object.keys(bundles).forEach(function(bId) {
        const bundle = bundles[bId];
        if (!bundle.parent) return;

        // Hide addons
        bundle.addons.forEach(function(addon) {
          const addonEl = findCartItemElement(addon.key) || findCartItemElement(addon.variant_id);
          if (addonEl) {
            addonEl.style.display = 'none';
            addonEl.classList.add('ikarus-hidden-addon');
          }
        });

        // Update parent price
        const parentEl = findCartItemElement(bundle.parent.key) || findCartItemElement(bundle.parent.variant_id);
        if (parentEl) {
          // Convert cents to standard currency format (rough fallback)
          // We use the cart's formatted total as a hint, or just generic formatting
          const formattedPrice = (bundle.totalPrice / 100).toFixed(2);
          
          const priceEls = parentEl.querySelectorAll('.price, .cart-item__price, .money, [data-cart-item-price]');
          priceEls.forEach(function(el) {
             if (!el.hasAttribute('data-ikarus-modified')) {
               el.setAttribute('data-ikarus-modified', 'true');
             }
             // Preserve currency symbols (e.g. $ or Rs or €) and only replace numbers
             el.innerText = el.innerText.replace(/[0-9.,]+/, formattedPrice);
          });
        }
      });
    }

    function findCartItemElement(identifier) {
      const selectors = [
        '[data-key="' + identifier + '"]',
        '[data-cart-item-key="' + identifier + '"]',
        '[data-item-key="' + identifier + '"]',
        '#CartItem-' + identifier,
        '.cart-item[data-variant-id="' + identifier + '"]'
      ];
      for (let i = 0; i < selectors.length; i++) {
        const el = document.querySelector(selectors[i]);
        if (el) return el.closest('tr, li, .cart-item, .cart__row');
      }
      const links = document.querySelectorAll('a[href*="' + identifier + '"]');
      if (links.length > 0) {
        for (let i = 0; i < links.length; i++) {
          const row = links[i].closest('tr, li, .cart-item, .cart__row');
          if (row) return row;
        }
      }
      return null;
    }

    // Attempt an initial run
    if (document.readyState === 'complete') {
      updateCartUI();
    } else {
      window.addEventListener('load', updateCartUI);
    }

    // Run when standard cart events fire
    document.addEventListener('cart:refresh', updateCartUI);
    document.addEventListener('cart:updated', updateCartUI);
    
    // Generic mutation observer for dynamic AJAX carts
    let debounceTimer;
    const observer = new MutationObserver(function(mutations) {
      let shouldUpdate = false;
      mutations.forEach(function(m) {
        if (m.addedNodes.length > 0) {
          shouldUpdate = true;
        }
      });
      if (shouldUpdate) {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(updateCartUI, 500);
      }
    });

    observer.observe(document.body, { childList: true, subtree: true });
  })();
</script>

{% schema %}
{
  "name": "Ikarus Cart Listener",
  "target": "body"
}
{% endschema %}