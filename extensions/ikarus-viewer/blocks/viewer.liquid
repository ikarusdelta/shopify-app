{%- liquid
  assign project_id = product.metafields.ikarus_delta.project_id.value
  assign mapping = product.metafields.ikarus_delta.mapping.value
-%}

{% if project_id != blank %}
  <div
    class="ikarus-viewer"
    id="ikd-viewer-{{ block.id }}"
    style="width:100%;height:{{ block.settings.height }}px;position:relative;"
    {{ block.shopify_attributes }}
  >
    <iframe
      id="ikd-iframe-{{ block.id }}"
      src="{{ block.settings.viewer_base_url }}?projectId={{ project_id }}"
      style="width:100%;height:100%;border:none;"
      allow="fullscreen"
      loading="lazy"
      title="{{ product.title }} 3D Viewer"
    ></iframe>
  </div>

  <script>
    (function() {
      const mapping = {{ mapping | json }};
      const iframe = document.getElementById('ikd-iframe-{{ block.id }}');

      if (!mapping || !iframe) return;

      const shopifyToViewer = {};
      mapping.forEach(function(row) {
        if (row.shopifyOption && row.viewerMenu) {
          const sName = row.shopifyOption.toLowerCase().trim();
          if (!shopifyToViewer[sName]) shopifyToViewer[sName] = [];
          shopifyToViewer[sName].push(row.viewerMenu);
        }
      });

      function sendSync() {
        if (!iframe.contentWindow) return;
        const config = {};
        const selectors = document.querySelectorAll('select[name^="options["], input[type="radio"][name^="options["]:checked');
        selectors.forEach(function(el) {
          const match = el.name.match(/options\[(.*)\]/);
          if (match) {
            const optName = match[1].toLowerCase().trim();
            if (shopifyToViewer[optName]) {
              shopifyToViewer[optName].forEach(function(vMenu) { config[vMenu] = el.value; });
            }
          }
        });
        if (Object.keys(config).length > 0) {
          iframe.contentWindow.postMessage({ type: 'IKARUS_CONFIG', config }, '*');
        }
      }

      document.body.addEventListener('change', function(e) {
        if (e.target.name && e.target.name.startsWith('options[')) sendSync();
      });

      iframe.onload = function() { setTimeout(sendSync, 1000); };
    })();
  </script>

{% elsif request.design_mode %}
  <div
    style="padding:24px;border:2px dashed #ccc;text-align:center;color:#666;font-family:sans-serif;"
    {{ block.shopify_attributes }}
  >
    <strong>IkarusDelta 3D Viewer</strong>
    <p style="margin:8px 0 0;font-size:0.875em;">
      No Project ID configured. Open the IkarusDelta app and set a Project ID for this product.
    </p>
  </div>
{% endif %}

{% schema %}
{
  "name": "IkarusDelta 3D Viewer",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "viewer_base_url",
      "label": "Viewer Base URL",
      "info": "Base URL of your IkarusDelta viewer. No trailing slash.",
      "default": "https://viewer.ikarus3d.com"
    },
    {
      "type": "range",
      "id": "height",
      "label": "Height",
      "min": 300,
      "max": 1000,
      "step": 50,
      "unit": "px",
      "default": 500
    }
  ]
}
{% endschema %}
